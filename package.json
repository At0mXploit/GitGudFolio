    "body-parser": "^1.19.0",
    "commander": "^2.20.0",
    "ejs": "^4.0.1",
    "express": "^4.17.0",
    "github-emoji": "^1.1.1",
    "got": "^11.8.5",
    "handlebars": "^4.1.2",
    "jsdom": "^28.1.0",
    "markdown-it": "^14.1.1",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-multimd-table": "^4.1.2",
    "markdown-it-task-lists": "^2.1.1",
    "ncp": "^2.0.0",
    "prettier": "^1.18.2"
  }
