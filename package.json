{
  "name": "gitgudfolio",
  "version": "0.1.5",
  "description": "A personal portfolio + blog for every GitHub user — but better.",
  "main": "build.js",
  "bin": {
    "gitgudfolio": "bin/gitfolio.js"
  },
  "scripts": {
    "ui": "OUT_DIR='./dist' node bin/gitfolio.js ui",
    "build": "OUT_DIR='./dist' node bin/gitfolio.js build",
    "update": "OUT_DIR='./dist' node bin/gitfolio.js update",
    "serve": "OUT_DIR='./dist' node bin/gitfolio.js run",
    "cli": "OUT_DIR='./dist' node bin/gitfolio.js",
    "clean": "rm -rf ./dist/*",
    "prettier": "prettier --write \"./**/*.{js,jsx,json,html,css,md}\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": {
    "name": "@At0mXploit",
    "email": "",
    "url": "https://github.com/At0mXploit"
  },
  "bugs": "https://github.com/At0mXploit/GitGudFolio/issues",
  "homepage": "https://github.com/At0mXploit/GitGudFolio",
  "keywords": [
    "personal-website",
    "github",
    "portfolio",
    "portfolio website",
    "blog website",
    "blog",
    "gitgudfolio",
    "git"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/At0mXploit/GitGudFolio"
  },
  "license": "GPL-3.0",
